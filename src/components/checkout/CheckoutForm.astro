    // ── Parcelas (Installments) ──
    const parcelasSelect = document.getElementById("field-parcelas") as HTMLSelectElement;

    function updateParcelas(total: number) {
        if (!parcelasSelect) return;
        parcelasSelect.innerHTML = "";
        for (let i = 1; i <= 12; i++) {
            const value = total / i;
            const label = i === 1
                ? `1x de ${formatPrice(total)} sem juros`
                : `${i}x de ${formatPrice(value)} sem juros`;
            const opt = document.createElement("option");
            opt.value = String(i);
            opt.textContent = label;
            parcelasSelect.appendChild(opt);
        }
    }

    totalPrice.subscribe((price) => {
        const shipping = shippingPrices[selectedShipping] || 0;
        updateParcelas(price + shipping);
    });

    // ── Copy PIX Code ──
    document.getElementById("btn-copy-pix")?.addEventListener("click", () => {
        const code = document.getElementById("pix-code")?.textContent || "";
        navigator.clipboard.writeText(code).then(() => {
