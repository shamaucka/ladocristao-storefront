---
import { Icon } from "astro-icon/components";

const estados = [
    "AC","AL","AP","AM","BA","CE","DF","ES","GO","MA","MT","MS","MG","PA",
    "PB","PR","PE","PI","RJ","RN","RS","RO","RR","SC","SP","SE","TO"
];
---

<form id="checkout-form" class="space-y-8" novalidate>
    <!-- ═══════ STEP 1 - IDENTIFICACAO ═══════ -->
    <section id="step-1" class="checkout-step" data-step="1">
        <div class="bg-white rounded-2xl border border-slate-100 shadow-xs p-6 md:p-8 space-y-6">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white text-xs font-black">
                    1
                </div>
                <h3 class="text-sm font-black uppercase tracking-widest text-slate-950">
                    Identificacao
                </h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="form-control w-full md:col-span-2">
                    <label class="label">
                        <span class="label-text font-bold text-[10px] uppercase tracking-widest text-slate-400">E-mail *</span>
                    </label>
                    <input
                        type="email"
                        name="email"
                        id="field-email"
                        placeholder="seu@email.com"
                        autocomplete="email"
                        class="input input-bordered w-full rounded-xl bg-slate-50 border-slate-200 focus:border-primary focus:bg-white transition-all font-medium"
                        required
                    />
                    <p class="text-xs text-red-500 mt-1 hidden" data-error="email">Informe um e-mail valido</p>
                </div>

                <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text font-bold text-[10px] uppercase tracking-widest text-slate-400">CPF *</span>
                    </label>
                    <input
                        type="text"
                        name="cpf"
                        id="field-cpf"
                        placeholder="000.000.000-00"
                        maxlength="14"
                        class="input input-bordered w-full rounded-xl bg-slate-50 border-slate-200 focus:border-primary focus:bg-white transition-all font-medium"
                        required
                    />
                    <p class="text-xs text-red-500 mt-1 hidden" data-error="cpf">Informe um CPF valido</p>
                </div>

                <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text font-bold text-[10px] uppercase tracking-widest text-slate-400">Nome Completo *</span>
                    </label>
                    <input
                        type="text"
                        name="name"
                        id="field-name"
                        placeholder="Nome e Sobrenome"
                        autocomplete="name"
                        class="input input-bordered w-full rounded-xl bg-slate-50 border-slate-200 focus:border-primary focus:bg-white transition-all font-medium"
                        required
                    />
                    <p class="text-xs text-red-500 mt-1 hidden" data-error="name">Informe seu nome completo</p>
                </div>

                <div class="form-control w-full md:col-span-2">
                    <label class="label">
                        <span class="label-text font-bold text-[10px] uppercase tracking-widest text-slate-400">Telefone *</span>
                    </label>
                    <input
                        type="tel"
                        name="phone"
                        id="field-phone"
                        placeholder="(00) 00000-0000"
                        maxlength="15"
                        autocomplete="tel"
                        class="input input-bordered w-full rounded-xl bg-slate-50 border-slate-200 focus:border-primary focus:bg-white transition-all font-medium"
                        required
                    />
                    <p class="text-xs text-red-500 mt-1 hidden" data-error="phone">Informe um telefone valido</p>
                </div>
            </div>

            <!-- Global validation error banner -->
            <div id="step1-error-banner" class="hidden bg-red-50 border border-red-200 rounded-xl px-4 py-3 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <p class="text-sm font-bold text-red-600">Preencha os campos destacados para continuar</p>
            </div>

            <button
                type="button"
                id="btn-next-1"
                class="w-full bg-primary hover:bg-primary/90 text-white rounded-xl py-4 font-black uppercase tracking-widest text-xs transition-all flex items-center justify-center gap-2 cursor-pointer"
            >
                Continuar para Entrega
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </button>
        </div>
    </section>

    <!-- ═══════ STEP 2 - ENTREGA ═══════ -->
    <section id="step-2" class="checkout-step hidden" data-step="2">
        <div class="bg-white rounded-2xl border border-slate-100 shadow-xs p-6 md:p-8 space-y-6">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white text-xs font-black">
                    2
                </div>
                <h3 class="text-sm font-black uppercase tracking-widest text-slate-950">
                    Entrega
                </h3>
            </div>

            <div class="space-y-4">
                <!-- CEP only - address fields appear after lookup -->
                <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text font-bold text-[10px] uppercase tracking-widest text-slate-400">CEP *</span>
                    </label>
                    <input
                        type="text"
                        name="cep"
                        id="field-cep"
                        placeholder="00000-000"
                        maxlength="9"
                        class="input input-bordered w-full rounded-xl bg-slate-50 border-slate-200 focus:border-primary focus:bg-white transition-all font-medium"
                        required
                    />
                    <p class="text-xs text-red-500 mt-1 hidden" data-error="cep">Informe um CEP valido</p>
                </div>

                <div id="cep-loading" class="hidden text-sm text-slate-500 flex items-center gap-2">
                    <span class="loading loading-spinner loading-xs"></span>
                    Buscando endereco...
                </div>

                <!-- Address fields - hidden until CEP lookup succeeds -->
                <div id="address-fields" class="hidden space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-[1fr_120px] gap-4">
                    <div class="form-control w-full">
                        <label class="label">
                            <span class="label-text font-bold text-[10px] uppercase tracking-widest text-slate-400">Rua *</span>
                        </label>
                        <input
                            type="text"
                            name="rua"
                            id="field-rua"
                            placeholder="Rua das Flores"
                            class="input input-bordered w-full rounded-xl bg-slate-50 border-slate-200 focus:border-primary focus:bg-white transition-all font-medium"
                            required
                        />
                        <p class="text-xs text-red-500 mt-1 hidden" data-error="rua">Informe a rua</p>
                    </div>
                    <div class="form-control w-full">
                        <label class="label">
                            <span class="label-text font-bold text-[10px] uppercase tracking-widest text-slate-400">Numero *</span>
                        </label>
                        <input
                            type="text"
                            name="numero"
                            id="field-numero"
                            placeholder="123"
                            class="input input-bordered w-full rounded-xl bg-slate-50 border-slate-200 focus:border-primary focus:bg-white transition-all font-medium"
                            required
                        />
                        <p class="text-xs text-red-500 mt-1 hidden" data-error="numero">Informe o numero</p>
                    </div>
                </div>

                <div class="form-control w-full">
                    <label class="label">
                        <span class="label-text font-bold text-[10px] uppercase tracking-widest text-slate-400">Complemento</span>
                    </label>
                    <input
                        type="text"
                        name="complemento"
                        id="field-complemento"
                        placeholder="Apto 42, Bloco B"
                        class="input input-bordered w-full rounded-xl bg-slate-50 border-slate-200 focus:border-primary focus:bg-white transition-all font-medium"
                    />
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="form-control w-full">
                        <label class="label">
                            <span class="label-text font-bold text-[10px] uppercase tracking-widest text-slate-400">Bairro *</span>
                        </label>
                        <input
                            type="text"
                            name="bairro"
                            id="field-bairro"
                            placeholder="Centro"
                            class="input input-bordered w-full rounded-xl bg-slate-50 border-slate-200 focus:border-primary focus:bg-white transition-all font-medium"
                            required
                        />
                        <p class="text-xs text-red-500 mt-1 hidden" data-error="bairro">Informe o bairro</p>
                    </div>
                    <div class="form-control w-full">
                        <label class="label">
                            <span class="label-text font-bold text-[10px] uppercase tracking-widest text-slate-400">Cidade *</span>
                        </label>
                        <input
                            type="text"
                            name="cidade"
                            id="field-cidade"
                            placeholder="Sao Paulo"
                            class="input input-bordered w-full rounded-xl bg-slate-50 border-slate-200 focus:border-primary focus:bg-white transition-all font-medium"
                            required
                        />
                        <p class="text-xs text-red-500 mt-1 hidden" data-error="cidade">Informe a cidade</p>
                    </div>
                    <div class="form-control w-full">
                        <label class="label">
                            <span class="label-text font-bold text-[10px] uppercase tracking-widest text-slate-400">Estado *</span>
                        </label>
                        <select
                            name="estado"
                            id="field-estado"
                            class="select select-bordered w-full rounded-xl bg-slate-50 border-slate-200 focus:border-primary focus:bg-white transition-all font-medium"
                            required
                        >
                            <option value="" disabled selected>UF</option>
                            {estados.map((uf) => (
                                <option value={uf}>{uf}</option>
                            ))}
                        </select>
                        <p class="text-xs text-red-500 mt-1 hidden" data-error="estado">Selecione o estado</p>
                    </div>
                </div>
                </div><!-- /address-fields -->
            </div>

            <!-- Shipping Options (hidden until CEP is filled) -->
            <div id="shipping-options" class="space-y-3 hidden">
                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Opcoes de Envio</p>
                <div id="shipping-loading" class="hidden text-center py-4">
                    <span class="loading loading-spinner loading-sm"></span>
                    <p class="text-xs text-slate-400 mt-2">Calculando frete...</p>
                </div>
                <div id="shipping-results"></div>
            </div>
            <p id="shipping-hint" class="text-xs text-slate-400 italic">Preencha o CEP acima para calcular o frete</p>

            <div class="flex gap-3">
                <button
                    type="button"
                    id="btn-back-2"
                    class="btn btn-outline border-slate-200 rounded-xl font-bold text-xs uppercase tracking-widest flex-1 cursor-pointer"
                >
                    <Icon name="lucide:arrow-left" class="w-4 h-4" />
                    Voltar
                </button>
                <button
                    type="button"
                    id="btn-next-2"
                    class="flex-[2] bg-primary hover:bg-primary/90 text-white rounded-xl py-4 font-black uppercase tracking-widest text-xs transition-all flex items-center justify-center gap-2 cursor-pointer"
                >
                    Continuar para Pagamento
                    <Icon name="lucide:arrow-right" class="w-4 h-4" />
                </button>
            </div>
        </div>
    </section>

    <!-- ═══════ STEP 3 - PAGAMENTO ═══════ -->
    <section id="step-3" class="checkout-step hidden" data-step="3">
        <div class="bg-white rounded-2xl border border-slate-100 shadow-xs p-6 md:p-8 space-y-6">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white text-xs font-black">
                    3
                </div>
                <h3 class="text-sm font-black uppercase tracking-widest text-slate-950">
                    Pagamento
                </h3>
            </div>

            <!-- Payment Method Tabs -->
            <div class="flex border-b border-slate-200">
                <button type="button" data-tab="pix" class="payment-tab flex items-center gap-2 px-4 py-3 text-xs font-bold uppercase tracking-widest border-b-2 border-primary text-primary cursor-pointer transition-colors">
                    <Icon name="lucide:qr-code" class="w-4 h-4" />
                    PIX
                </button>
                <button type="button" data-tab="cartao" class="payment-tab flex items-center gap-2 px-4 py-3 text-xs font-bold uppercase tracking-widest border-b-2 border-transparent text-slate-400 hover:text-slate-600 cursor-pointer transition-colors">
                    <Icon name="lucide:credit-card" class="w-4 h-4" />
                    Cartao
                </button>

            </div>

            <!-- PIX Panel -->
            <div id="panel-pix" class="payment-panel space-y-6">
                <div id="pix-generate-section">
                    <div class="bg-emerald-50 rounded-lg p-3 flex items-center gap-2 mb-4">
                        <Icon name="lucide:percent" class="w-4 h-4 text-emerald-600" />
                        <p class="text-xs font-bold text-emerald-700">5% de desconto no PIX</p>
                    </div>
                    <button
                        type="button"
                        id="btn-generate-pix"
                        class="w-full bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl py-4 font-black uppercase tracking-widest text-xs transition-all flex items-center justify-center gap-2 cursor-pointer"
                    >
                        <Icon name="lucide:qr-code" class="w-4 h-4" />
                        Gerar QR Code PIX
                    </button>
                </div>
                <div id="pix-qr-section" class="hidden">
                    <div class="bg-slate-50 rounded-xl p-6 text-center space-y-4">
                        <div id="pix-qr-container" class="w-44 h-44 bg-white border-2 border-slate-200 rounded-xl mx-auto flex items-center justify-center overflow-hidden">
                            <span class="loading loading-spinner loading-lg"></span>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-2">Pix Copia e Cola</p>
                            <div class="flex items-center gap-2 bg-white rounded-lg p-2.5 border border-slate-200 max-w-sm mx-auto">
                                <code id="pix-code" class="text-[11px] text-slate-500 flex-1 font-mono truncate min-w-0">Gerando...</code>
                                <button type="button" id="btn-copy-pix" class="flex-shrink-0 bg-slate-900 text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-md hover:bg-slate-800 transition-colors cursor-pointer">
                                    Copiar
                                </button>
                            </div>
                        </div>
                        <p id="pix-status-text" class="text-xs text-slate-400">Aguardando pagamento...</p>
                    </div>
                </div>
            </div>

            <!-- Cartao Panel (PayPal Plus - iframe seguro) -->
            <div id="panel-cartao" class="payment-panel hidden space-y-4">
                <!-- Placeholder antes de inicializar -->
                <div id="ppplus-placeholder" class="bg-slate-50 rounded-xl p-6 text-center space-y-3">
                    <p class="text-sm text-slate-600 font-medium">Selecione a aba <strong>Cartao</strong> para carregar o formulario seguro</p>
                    <div class="flex items-center justify-center gap-2 text-xs text-slate-400">
                        <Icon name="lucide:shield-check" class="w-4 h-4 text-emerald-500" />
                        <span>Dados processados com seguranca via PayPal</span>
                    </div>
                </div>
                <!-- Loading -->
                <div id="ppplus-loading" class="hidden text-center py-10 space-y-3">
                    <span class="loading loading-spinner loading-md text-slate-400"></span>
                    <p class="text-sm text-slate-400">Carregando formulario seguro de cartao...</p>
                </div>
                <!-- PayPal Plus iframe injected here -->
                <div id="ppplus" class="w-full"></div>
                <p id="card-error-msg" class="text-red-500 text-xs font-bold hidden text-center"></p>
                <!-- Finalizar Compra button - shown after PPPlus iframe loads -->
                <button
                    type="button"
                    id="btn-ppplus-pay"
                    class="hidden w-full bg-slate-900 hover:bg-slate-800 text-white rounded-xl py-4 font-black uppercase tracking-widest text-xs transition-all flex items-center justify-center gap-2 cursor-pointer"
                >
                    <Icon name="lucide:lock" class="w-4 h-4" />
                    Finalizar Compra
                </button>
            </div>


            <!-- Back button for step 3 -->
            <button
                type="button"
                id="btn-back-3"
                class="w-full btn btn-outline border-slate-200 rounded-xl font-bold text-xs uppercase tracking-widest cursor-pointer"
            >
                <Icon name="lucide:arrow-left" class="w-4 h-4" />
                Voltar para Entrega
            </button>
        </div>
    </section>
</form>

<style is:global>
    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        20% { transform: translateX(-6px); }
        40% { transform: translateX(6px); }
        60% { transform: translateX(-4px); }
        80% { transform: translateX(4px); }
    }
    .shake { animation: shake 0.4s ease-in-out; }
</style>

<script>
    import { totalPrice, cartItems, clearCart, isPromoActive, getEffectiveUnitPrice } from "../../store/cartStore";
    import {
        genEventId,
        trackMetaInitiateCheckout, trackTikTokInitiateCheckout, trackGoogleBeginCheckout,
        trackMetaPurchase, trackTikTokPurchase, trackGooglePurchase,
        setEnhancedConversionsData, saveUserData,
    } from '../../lib/tracking';

    const TRACK_API = window.location.hostname === "localhost"
        ? "http://localhost:4000/api/store/track"
        : "https://api.ladocristao.com.br/api/store/track";
    const _sessId = localStorage.getItem("tess_vid") || "";
    const _sentSteps = new Set<string>();
    function trackCheckoutStep(step: string, orderId?: string) {
        if (_sentSteps.has(step) || !_sessId) return;
        _sentSteps.add(step);
        fetch(TRACK_API, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ event: "checkout_step", step, sessionId: _sessId, orderId }),
            keepalive: true,
        }).catch(() => {});
    }

    function initCheckout() {
    // Verifica se o DOM do checkout esta pronto
    if (!document.getElementById("btn-next-1")) {
        setTimeout(initCheckout, 100);
        return;
    }

    // ── Funnel: cliente chegou no checkout ──
    trackCheckoutStep("cart");

    function getTotalQty() {
        return cartItems.get().reduce((sum: number, item: any) => sum + item.quantity, 0);
    }

    // Frete fixo R$19,90 — sem frete gratis
    function isEligibleForFreeShipping() {
        return false;
    }

    // ── State ──
    let currentStep = 1;
    let selectedShipping = "pac";
    const shippingPrices: Record<string, number> = { pac: 19.90, sedex: 32.90 };
    let actualShippingPrice = 0; // Começa zerado — só define após CEP no step 2

    const formatPrice = (price: number) =>
        new Intl.NumberFormat("pt-BR", { style: "currency", currency: "BRL" }).format(price);

    // ── Step Navigation ──
    function showStep(step: number) {
        document.querySelectorAll(".checkout-step").forEach((el) => {
            el.classList.add("hidden");
        });
        const target = document.getElementById(`step-${step}`);
        if (target) {
            target.classList.remove("hidden");
            target.scrollIntoView({ behavior: "smooth", block: "start" });
        }
        currentStep = step;
        document.dispatchEvent(new CustomEvent("checkout:step-changed", { detail: { step } }));
    }

    // Navigation buttons
    const btnNext1 = document.getElementById("btn-next-1");
    const step1ErrorBanner = document.getElementById("step1-error-banner");

    btnNext1?.addEventListener("click", () => {
        // Force browser autofill to commit values before validation
        ["field-email", "field-cpf", "field-name", "field-phone"].forEach((id) => {
            const el = document.getElementById(id) as HTMLInputElement;
            if (el) el.dispatchEvent(new Event("change", { bubbles: true }));
        });

        // Força aplicação das máscaras antes da validação (evita bloqueio por autofill/paste sem mascara)
        if (cpfInput) cpfInput.value = maskCPF(cpfInput.value);
        if (phoneInput) phoneInput.value = maskPhone(phoneInput.value);

        if (validateStep1()) {
            step1ErrorBanner?.classList.add("hidden");
            trackCheckoutStep("identification");
            showStep(2);
            // InitiateCheckout — dispara no step 1→2
            try {
                const total = totalPrice.get();
                const items = cartItems.get();
                trackMetaInitiateCheckout(total, items.reduce((s: number, i: any) => s + i.quantity, 0));
                trackTikTokInitiateCheckout(total);
                trackGoogleBeginCheckout(total, items.map((i: any) => ({ id: i.id, name: i.name, price: i.price, quantity: i.quantity })));
                const form = getFormData();
                saveUserData({ email: form.email, phone: form.phone, name: form.name });
            } catch (e) {}
        } else {
            // Show global error banner
            step1ErrorBanner?.classList.remove("hidden");
            step1ErrorBanner?.scrollIntoView({ behavior: "smooth", block: "center" });
            // Shake the button
            btnNext1.classList.add("shake");
            setTimeout(() => btnNext1.classList.remove("shake"), 400);
        }
    });
    const btnNext2 = document.getElementById("btn-next-2");
    btnNext2?.addEventListener("click", () => {
        ["field-cep", "field-rua", "field-numero", "field-bairro", "field-cidade", "field-estado"].forEach((id) => {
            const el = document.getElementById(id) as HTMLInputElement;
            if (el) el.dispatchEvent(new Event("change", { bubbles: true }));
        });
        if (cepInput) cepInput.value = maskCEP(cepInput.value);
        if (validateStep2()) {
            trackCheckoutStep("address");
            trackCheckoutStep("payment");
            showStep(3);
        } else {
            btnNext2.classList.add("shake");
            setTimeout(() => btnNext2.classList.remove("shake"), 400);
        }
    });
    document.getElementById("btn-back-2")?.addEventListener("click", () => showStep(1));
    document.getElementById("btn-back-3")?.addEventListener("click", () => showStep(2));

    // Listen for step navigation from page
    document.addEventListener("checkout:goto-step", ((e: CustomEvent) => {
        const targetStep = e.detail.step;
        // Only allow going to steps that are completed or current
        if (targetStep <= currentStep) {
            showStep(targetStep);
        }
    }) as EventListener);

    // ── Input Masks ──
    function maskCPF(value: string) {
        return value.replace(/\D/g, '')
            .replace(/(\d{3})(\d)/, '$1.$2')
            .replace(/(\d{3})(\d)/, '$1.$2')
            .replace(/(\d{3})(\d{1,2})$/, '$1-$2');
    }

    function maskPhone(value: string) {
        return value.replace(/\D/g, '')
            .replace(/(\d{2})(\d)/, '($1) $2')
            .replace(/(\d{5})(\d)/, '$1-$2');
    }

    function maskCEP(value: string) {
        return value.replace(/\D/g, '')
            .replace(/(\d{5})(\d)/, '$1-$2');
    }

    function maskCardNumber(value: string) {
        return value.replace(/\D/g, '')
            .replace(/(\d{4})(?=\d)/g, '$1 ')
            .trim();
    }

    function maskExpiry(value: string) {
        return value.replace(/\D/g, '')
            .replace(/(\d{2})(\d)/, '$1/$2');
    }

    const cpfInput = document.getElementById("field-cpf") as HTMLInputElement;
    const phoneInput = document.getElementById("field-phone") as HTMLInputElement;
    const cepInput = document.getElementById("field-cep") as HTMLInputElement;
    const cardNumberInput = document.getElementById("field-card-number") as HTMLInputElement;
    const cardExpiryInput = document.getElementById("field-card-expiry") as HTMLInputElement;
    const cardCvvInput = document.getElementById("field-card-cvv") as HTMLInputElement;

    // Helper: aplica mascara em todos os eventos relevantes (input/change/blur/paste)
    function bindMask(el: HTMLInputElement | null, fn: (v: string) => string) {
        if (!el) return;
        const apply = () => { el.value = fn(el.value); };
        el.addEventListener("input", apply);
        el.addEventListener("change", apply);
        el.addEventListener("blur", apply);
        // Paste: aguarda o valor ser inserido antes de aplicar
        el.addEventListener("paste", () => setTimeout(apply, 0));
    }

    bindMask(cpfInput, maskCPF);
    bindMask(phoneInput, maskPhone);
    bindMask(cepInput, maskCEP);
    bindMask(cardNumberInput, maskCardNumber);
    bindMask(cardExpiryInput, maskExpiry);
    bindMask(cardCvvInput, (v) => v.replace(/\D/g, ''));

    // ── ViaCEP Auto-fill ──
    const cepLoading = document.getElementById("cep-loading");
    const ruaInput = document.getElementById("field-rua") as HTMLInputElement;
    const bairroInput = document.getElementById("field-bairro") as HTMLInputElement;
    const cidadeInput = document.getElementById("field-cidade") as HTMLInputElement;
    const estadoInput = document.getElementById("field-estado") as HTMLSelectElement;

    const addressFields = document.getElementById("address-fields");

    async function fetchCEP(cep: string) {
        const cleanCep = cep.replace(/\D/g, "");
        if (cleanCep.length !== 8) return;

        cepLoading?.classList.remove("hidden");
        addressFields?.classList.add("hidden");
        try {
            const res = await fetch(`https://viacep.com.br/ws/${cleanCep}/json/`);
            const data = await res.json();

            if (!data.erro) {
                if (ruaInput && data.logradouro) ruaInput.value = data.logradouro;
                if (bairroInput && data.bairro) bairroInput.value = data.bairro;
                if (cidadeInput && data.localidade) cidadeInput.value = data.localidade;
                if (estadoInput && data.uf) estadoInput.value = data.uf;
                // Show address fields and focus on numero
                addressFields?.classList.remove("hidden");
                document.getElementById("field-numero")?.focus();
            } else {
                // CEP not found - still show fields for manual entry
                addressFields?.classList.remove("hidden");
            }
        } catch (err) {
            console.error("Erro ao buscar CEP:", err);
            addressFields?.classList.remove("hidden");
        } finally {
            cepLoading?.classList.add("hidden");
        }
    }

    // Auto-fetch when CEP is complete (8 digits typed OR autocomplete)
    function onCepFilled() {
        const clean = cepInput.value.replace(/\D/g, "");
        if (clean.length === 8) { fetchCEP(cepInput.value); calcShipping(cepInput.value); }
    }
    cepInput?.addEventListener("input", onCepFilled);
    cepInput?.addEventListener("change", onCepFilled);  // browser autocomplete fires change

    // ── Shipping Calculation from API ──
    const shippingOptions = document.getElementById("shipping-options");
    const shippingResults = document.getElementById("shipping-results");
    const shippingLoading = document.getElementById("shipping-loading");
    const shippingHint = document.getElementById("shipping-hint");

    async function calcShipping(cep: string) {
        const cleanCep = cep.replace(/\D/g, "");
        if (cleanCep.length !== 8) return;

        shippingOptions?.classList.remove("hidden");
        shippingLoading?.classList.remove("hidden");
        shippingHint?.classList.add("hidden");
        if (shippingResults) shippingResults.innerHTML = "";

        try {
            const res = await fetch("https://api.ladocristao.com.br/api/store/shipping", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ action: "calculate", cep: cleanCep, cartTotal: totalPrice.get() }),
            });
            const data = await res.json();
            shippingLoading?.classList.add("hidden");

            if (data.shipping) {
                const s = data.shipping;
                const freeByPromo = isEligibleForFreeShipping();
                const isFree = s.free || freeByPromo;
                const priceText = isFree ? "Gratis" : `R$ ${(s.cost / 100).toFixed(2).replace(".", ",")}`;
                if (shippingResults) {
                    shippingResults.innerHTML = `
                        <label class="flex items-center gap-4 p-4 border border-primary rounded-xl cursor-pointer bg-primary/5">
                            <input type="radio" name="shipping" value="standard" class="radio radio-primary radio-sm" checked />
                            <div class="flex-1">
                                <p class="font-bold text-sm text-slate-950">Envio Padrao</p>
                                <p class="text-xs text-slate-400">${s.message || (s.delivery_days_min + " a " + s.delivery_days_max + " dias uteis")}</p>
                            </div>
                            <span class="font-black text-sm ${isFree ? "text-emerald-600" : "text-slate-950"}">${priceText}</span>
                        </label>
                    `;
                    selectedShipping = "standard";
                    const shippingPrice = isFree ? 0 : s.cost / 100;
                    actualShippingPrice = shippingPrice;
                    document.dispatchEvent(new CustomEvent("checkout:shipping-changed", {
                        detail: { method: "standard", price: shippingPrice, free: isFree }
                    }));
                    // shipping step removido do funil
                }
            } else {
                if (shippingResults) shippingResults.innerHTML = `<p class="text-sm text-red-500">${data.error || "Erro ao calcular frete"}</p>`;
            }
        } catch (err) {
            shippingLoading?.classList.add("hidden");
            if (shippingResults) shippingResults.innerHTML = `<p class="text-sm text-red-500">Erro ao calcular frete</p>`;
        }
    }

    // ── Shipping Selection ──
    document.addEventListener("click", (e) => {
        const radio = (e.target as HTMLElement).closest('input[name="shipping"]') as HTMLInputElement;
        if (radio) {
            selectedShipping = radio.value;
        }
    });

    // Frete começa zerado — só atualiza após CEP no step 2
    document.dispatchEvent(new CustomEvent("checkout:shipping-changed", {
        detail: { method: "", price: 0, free: isEligibleForFreeShipping(), pending: true }
    }));

    // ── Payment Tabs ──
    const paymentTabs = document.querySelectorAll(".payment-tab");
    const paymentPanels = document.querySelectorAll(".payment-panel");

    paymentTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
