    // Event ID para deduplicação Pixel + CAPI (gerado uma vez, usado em ambos)
    const sharedPurchaseEventId = genEventId();

    // Create order in backend
    async function createOrder(): Promise<string | null> {
        const form = getFormData();
        const items = cartItems.get();
        const total = totalPrice.get(); // já inclui promo por categoria

        try {
            // unit_price em centavos — usa preco efetivo por categoria
            const orderItems = items.map(i => ({
                product_id: i.id,
                title: i.name,
                sku: (i as any).sku || i.id,
                quantity: i.quantity,
                unit_price: Math.round(getEffectiveUnitPrice(i, items) * 100),
                original_price: Math.round(i.price * 100),
            }));

            const subtotalCents = orderItems.reduce((s, i) => s + i.unit_price * i.quantity, 0);
            const fullCents = items.reduce((s, i) => s + Math.round(i.price * 100) * i.quantity, 0);
            const discountCents = Math.max(0, fullCents - subtotalCents);

            const res = await fetch(API_URL + "/store/orders", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    action: "create",
                    email: form.email,
                    name: form.name,
                    cpf: form.cpf.replace(/\D/g, ""),
                    phone: form.phone.replace(/\D/g, ""),
                    items: orderItems,
                    subtotal_override: subtotalCents,
                    discount_amount: discountCents,
                    shipping: {
                        address_line1: `${form.rua}, ${form.numero}`,
                        address_line2: form.complemento,
                        neighborhood: form.bairro,
                        city: form.cidade,
                        state: form.estado,
                        postal_code: form.cep.replace(/\D/g, ""),
                    },
                    // Dados para CAPI (salvos no pedido para uso nos webhooks)
                    tracking_data: {
                        fbp: typeof (window as any)._fbGetCookies === 'function' ? (window as any)._fbGetCookies()?.fbp : undefined,
                        fbc: typeof (window as any)._fbGetCookies === 'function' ? (window as any)._fbGetCookies()?.fbc : undefined,
                        user_agent: navigator.userAgent,
                        purchase_event_id: sharedPurchaseEventId, // mesmo ID para Pixel e CAPI
                    },
                }),
            });
            const data = await res.json();
            if (data.error) { console.error("Order error:", data.error); return null; }
            // Guarda display_id para o ticket de confirmação
            if (data.order?.display_id) {
                (window as any).__tessOrderDisplayId = data.order.display_id;
            }
            return data.order?.id || null;
        } catch (err) {
            console.error("Erro ao criar pedido:", err);
            return null;
        }
    }

    // ── PIX via Woovi ──
    document.getElementById("btn-generate-pix")?.addEventListener("click", async () => {
        const btn = document.getElementById("btn-generate-pix") as HTMLButtonElement;
        btn.disabled = true;
        btn.innerHTML = '<span class="loading loading-spinner loading-sm"></span> Gerando PIX...';

        // Set Enhanced Conversions data before payment
        try {
            const form = getFormData();
            await setEnhancedConversionsData({
                email: form.email, phone: form.phone, name: form.name,
                address: { zip: form.cep, city: form.cidade, state: form.estado },
            });
        } catch (e) {}

        const orderId = await createOrder();
        if (!orderId) {
            btn.disabled = false;
            btn.innerHTML = 'Erro - Tente novamente';
            return;
        }
        trackCheckoutStep("order_created", orderId);

        try {
            const form = getFormData();
            const total = totalPrice.get();
            const pixTotal = Math.round((total + actualShippingPrice) * 0.95 * 100); // subtotal + frete, 5% desconto PIX

            const res = await fetch(API_URL + "/store/payments", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    action: "pix_create",
                    orderId,
                    displayId: orderId.substring(0, 8),
                    amount: pixTotal,
                    customerName: form.name,
                    customerEmail: form.email,
                    customerCpf: form.cpf,
                }),
            });
            const data = await res.json();

            // Show QR code
            document.getElementById("pix-generate-section")?.classList.add("hidden");
            document.getElementById("pix-qr-section")?.classList.remove("hidden");

            const qrContainer = document.getElementById("pix-qr-container");
            if (qrContainer && data.qrCodeImage) {
                qrContainer.innerHTML = `<img src="${data.qrCodeImage}" alt="QR Code PIX" class="w-full h-full object-contain" />`;
            } else if (qrContainer) {
                qrContainer.innerHTML = `<div class="text-center"><p class="text-xs text-slate-400">Use o codigo abaixo</p></div>`;
            }

            const pixCode = document.getElementById("pix-code");
            if (pixCode && data.brCode) {
                pixCode.textContent = data.brCode;
            }

            // Poll for payment status
            if (data.chargeId) {
                const pollInterval = setInterval(async () => {
                    try {
                        const statusRes = await fetch(API_URL + "/store/payments", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ action: "pix_status", chargeId: data.chargeId }),
                        });
                        const statusData = await statusRes.json();
                        if (statusData.paid) {
                            clearInterval(pollInterval);
                            const statusText = document.getElementById("pix-status-text");
                            if (statusText) {
                                statusText.className = "text-sm font-bold text-emerald-600";
                                statusText.textContent = "Pagamento confirmado!";
                            }
                            // Fire Purchase tracking
                            try {
                                const items = cartItems.get();
                                const total = totalPrice.get();
                                const pixTotal = Math.round(total * 0.95 * 100) / 100;
                                const purchaseItems = items.map((i: any) => ({ id: i.id, name: i.name, price: i.price, quantity: i.quantity }));
                                trackMetaPurchase({ orderId: orderId!, value: pixTotal, items: purchaseItems, eventId: sharedPurchaseEventId });
                                trackTikTokPurchase({ orderId: orderId!, value: pixTotal });
                                trackGooglePurchase({ orderId: orderId!, value: pixTotal, items: purchaseItems });
                            } catch (e) {}
                            trackCheckoutStep("purchase", orderId || undefined);
                            // Mostra ticket de confirmação (mesmo fluxo do cartão)
                            // NÃO chamar clearCart() — completePurchase() no handler já limpa
                            const form = getFormData();
                            document.dispatchEvent(new CustomEvent("checkout:complete", { detail: { name: form.name, displayId: (window as any).__tessOrderDisplayId || "" } }));
                        }
                    } catch {}
                }, 5000); // Check every 5 seconds

                // Stop polling after 15 minutes
                setTimeout(() => clearInterval(pollInterval), 15 * 60 * 1000);
            }
        } catch (err) {
            console.error("Erro PIX:", err);
            btn.disabled = false;
            btn.innerHTML = 'Erro - Tente novamente';
        }
    });

    // ── PayPal Plus (iframe) ──
    let ppplusOrderId: string | null = null;
    let ppplusPaymentId: string | null = null;
    let ppplusInitialized = false;
    let ppplusRef: any = null;

    async function initPayPalPlus() {
        if (ppplusInitialized) return;
        const errorMsg = document.getElementById("card-error-msg");
        const placeholder = document.getElementById("ppplus-placeholder");
        const loading = document.getElementById("ppplus-loading");

        placeholder?.classList.add("hidden");
        loading?.classList.remove("hidden");
        if (errorMsg) errorMsg.classList.add("hidden");

        // Set Enhanced Conversions data when user reaches payment step
        try {
            const form = getFormData();
            await setEnhancedConversionsData({
                email: form.email, phone: form.phone, name: form.name,
                address: { zip: form.cep, city: form.cidade, state: form.estado },
            });
        } catch (e) {}

        // Create order in backend
        const orderId = await createOrder();
        if (!orderId) {
            loading?.classList.add("hidden");
            placeholder?.classList.remove("hidden");
            if (errorMsg) { errorMsg.textContent = "Erro ao criar pedido. Tente novamente."; errorMsg.classList.remove("hidden"); }
            return;
        }
        ppplusOrderId = orderId;
        trackCheckoutStep("order_created", orderId);

        // Create PayPal Plus payment in backend
        try {
            const form = getFormData();
            const total = totalPrice.get();
            const res = await fetch(API_URL + "/store/payments", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    action: "ppplus_create",
                    orderId,
                    displayId: orderId.substring(0, 8),
                    amount: Math.round((total + actualShippingPrice) * 100), // subtotal + frete
                    customerName: form.name,
                    customerEmail: form.email,
                    customerCpf: form.cpf.replace(/\D/g, ""),
                }),
            });
            const data = await res.json();
            if (data.error) throw new Error(data.error);

            ppplusPaymentId = data.paymentId;
            loadPayPalPlusScript(data.approvalUrl);
        } catch (err: any) {
            loading?.classList.add("hidden");
            placeholder?.classList.remove("hidden");
            if (errorMsg) { errorMsg.textContent = err.message || "Erro ao inicializar pagamento."; errorMsg.classList.remove("hidden"); }
        }
    }

    function loadPayPalPlusScript(approvalUrl: string) {
        const existing = document.getElementById("ppplus-script");
        if (existing && (window as any).PAYPAL?.apps?.PPP) {
            renderPayPalPlus(approvalUrl);
            return;
        }
        const script = document.createElement("script");
        script.id = "ppplus-script";
        script.src = "https://www.paypalobjects.com/webstatic/ppplusdcc/ppplusdcc.min.js";
        script.async = true;
        script.onload = () => renderPayPalPlus(approvalUrl);
        script.onerror = () => {
            document.getElementById("ppplus-loading")?.classList.add("hidden");
            document.getElementById("ppplus-placeholder")?.classList.remove("hidden");
            const em = document.getElementById("card-error-msg");
            if (em) { em.textContent = "Erro ao carregar formulario de pagamento."; em.classList.remove("hidden"); }
        };
        document.body.appendChild(script);
    }

    function renderPayPalPlus(approvalUrl: string) {
        const PP = (window as any).PAYPAL;
        if (!PP?.apps?.PPP) {
            document.getElementById("ppplus-loading")?.classList.add("hidden");
            document.getElementById("ppplus-placeholder")?.classList.remove("hidden");
            return;
        }
        const container = document.getElementById("ppplus");
        if (container) container.innerHTML = "";
        const form = getFormData();

        ppplusRef = PP.apps.PPP({
            approvalUrl,
            placeholder: "ppplus",
            mode: "live",
            country: "BR",
            language: "pt_BR",
            payerEmail: form.email,
            payerFirstName: form.name.split(" ")[0],
            payerLastName: form.name.split(" ").slice(1).join(" ") || form.name.split(" ")[0],
            payerPhone: form.phone.replace(/\D/g, ""),
            payerTaxId: form.cpf.replace(/\D/g, ""),
            onContinue: async (_: string, payerId: string) => {
                await executePayPalPlus(payerId);
            },
            onError: (err: any) => {
                const detail = typeof err === "object" ? JSON.stringify(err) : String(err);
                const msg = detail.includes("INTERNAL_SERVICE_ERROR") || detail.includes("NOT_ELIGIBLE")
                    ? "Pagamento via cartao indisponivel no momento. Use PIX."
                    : "Erro no pagamento. Verifique os dados do cartao.";
                const em = document.getElementById("card-error-msg");
                if (em) { em.textContent = msg; em.classList.remove("hidden"); }
            },
            onLoad: () => {
                document.getElementById("ppplus-loading")?.classList.add("hidden");
                document.getElementById("btn-ppplus-pay")?.classList.remove("hidden");
                ppplusInitialized = true;
            },
        });
    }

    async function executePayPalPlus(payerId: string) {
        const errorMsg = document.getElementById("card-error-msg");
        if (errorMsg) errorMsg.classList.add("hidden");
        // Usa o mesmo event ID compartilhado para deduplicação Pixel + CAPI
        const purchaseEventId = sharedPurchaseEventId;
        // Read fbp/fbc cookies for CAPI matching
        const fbCookies = typeof (window as any)._fbGetCookies === 'function' ? (window as any)._fbGetCookies() : {};
        const ttclid = typeof document !== 'undefined'
            ? (document.cookie.split(';').find((c: string) => c.trim().startsWith('ttclid='))?.split('=')?.[1] || '')
            : '';
        try {
            const res = await fetch(API_URL + "/store/payments", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    action: "ppplus_execute",
                    orderId: ppplusOrderId,
                    paymentId: ppplusPaymentId,
                    payerId,
                    eventId: purchaseEventId,
                    fbp: fbCookies.fbp,
                    fbc: fbCookies.fbc,
                    ttclid,
                }),
            });
            const data = await res.json();
            if (data.error) throw new Error(data.error);
            if (data.paid) {
                // Fire Purchase tracking with same eventId sent to CAPI (deduplication)
                try {
                    const items = cartItems.get();
                    const total = totalPrice.get();
                    const purchaseItems = items.map((i: any) => ({ id: i.id, name: i.name, price: i.price, quantity: i.quantity }));
                    console.log("[Tess] Purchase tracking:", { orderId: ppplusOrderId, total, items: purchaseItems.length, hasFbq: !!(window as any).fbq });
                    trackMetaPurchase({ orderId: ppplusOrderId!, value: total, items: purchaseItems, eventId: purchaseEventId });
                    trackTikTokPurchase({ orderId: ppplusOrderId!, value: total });
                    trackGooglePurchase({ orderId: ppplusOrderId!, value: total, items: purchaseItems });
                } catch (e) { console.error("[Tess] Purchase tracking error:", e); }
                trackCheckoutStep("purchase", ppplusOrderId || undefined);
                // NÃO chamar clearCart() aqui — completePurchase() no handler do checkout:complete já limpa
                const form = getFormData();
                document.dispatchEvent(new CustomEvent("checkout:complete", { detail: { name: form.name, displayId: (window as any).__tessOrderDisplayId || "" } }));
            }
        } catch (err: any) {
            if (errorMsg) { errorMsg.textContent = err.message || "Erro ao finalizar pagamento."; errorMsg.classList.remove("hidden"); }
            // Re-enable button on error
            const btn = document.getElementById("btn-ppplus-pay") as HTMLButtonElement;
            if (btn) {
                btn.disabled = false;
                btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Finalizar Compra';
            }
        }
    }

    // ── Validation ──
    function showError(field: string, message?: string) {
        const el = document.querySelector(`[data-error="${field}"]`) as HTMLElement;
        if (el) {
            if (message) el.textContent = message;
            el.classList.remove("hidden");
        }
        // Add red border + ring to the corresponding input/select
        const input = document.getElementById(`field-${field}`) as HTMLElement;
        if (input) {
            input.classList.add("border-red-500", "ring-1", "ring-red-300");
            input.classList.remove("border-slate-200");
        }
    }

    function clearFieldError(field: string) {
        const el = document.querySelector(`[data-error="${field}"]`) as HTMLElement;
        if (el) el.classList.add("hidden");
        const input = document.getElementById(`field-${field}`) as HTMLElement;
        if (input) {
            input.classList.remove("border-red-500", "ring-1", "ring-red-300");
            input.classList.add("border-slate-200");
        }
        // Hide banner if all errors are now cleared
        const anyVisible = document.querySelectorAll("[data-error]:not(.hidden)").length;
        if (anyVisible === 0) {
            document.getElementById("step1-error-banner")?.classList.add("hidden");
        }
    }

    function hideAllErrors() {
        document.querySelectorAll("[data-error]").forEach((el) => el.classList.add("hidden"));
        // Remove red borders + rings from all fields
        const fields = ["email", "cpf", "name", "phone", "cep", "rua", "numero", "bairro", "cidade", "estado"];
        fields.forEach((f) => {
            const input = document.getElementById(`field-${f}`) as HTMLElement;
            if (input) {
                input.classList.remove("border-red-500", "ring-1", "ring-red-300");
                input.classList.add("border-slate-200");
            }
        });
    }

    // Clear error on input for better UX
    ["email", "cpf", "name", "phone", "cep", "rua", "numero", "bairro", "cidade", "estado"].forEach((field) => {
        const el = document.getElementById(`field-${field}`);
        if (el) {
            el.addEventListener("input", () => clearFieldError(field));
            el.addEventListener("change", () => clearFieldError(field));
        }
    });

    function validarCPF(cpf: string): boolean {
        if (cpf.length !== 11) return false;
        // Rejeita CPFs com todos os dígitos iguais (ex: 111.111.111-11)
        if (/^(\d)\1+$/.test(cpf)) return false;
        // Validação dos dígitos verificadores
        let soma = 0;
        for (let i = 0; i < 9; i++) soma += parseInt(cpf[i]) * (10 - i);
        let resto = (soma * 10) % 11;
        if (resto === 10) resto = 0;
        if (resto !== parseInt(cpf[9])) return false;
        soma = 0;
        for (let i = 0; i < 10; i++) soma += parseInt(cpf[i]) * (11 - i);
        resto = (soma * 10) % 11;
        if (resto === 10) resto = 0;
        return resto === parseInt(cpf[10]);
    }

    function validateStep1(): boolean {
        hideAllErrors();
        let valid = true;
        let firstError: string | null = null;

        const emailEl = document.getElementById("field-email") as HTMLInputElement;
        const cpfEl = document.getElementById("field-cpf") as HTMLInputElement;
        const nameEl = document.getElementById("field-name") as HTMLInputElement;
        const phoneEl = document.getElementById("field-phone") as HTMLInputElement;

        const email = emailEl?.value?.trim() || "";
        const cpf = cpfEl?.value || "";
        const name = nameEl?.value?.trim() || "";
        const phone = phoneEl?.value || "";

        // Aplica máscaras caso ainda não tenham sido aplicadas
        if (cpfEl && cpf) cpfEl.value = maskCPF(cpf);
        if (phoneEl && phone) phoneEl.value = maskPhone(phone);

        // Email
        if (!email || !email.includes("@") || !email.includes(".")) {
            showError("email", "Informe um e-mail valido");
            valid = false;
            if (!firstError) firstError = "email";
        } else {
            const domain = email.split("@")[1]?.toLowerCase();
            const typos: Record<string, string> = {
                "gamil.com": "gmail.com", "gmai.com": "gmail.com", "gmial.com": "gmail.com", "gmal.com": "gmail.com",
                "hormail.com": "hotmail.com", "hotmal.com": "hotmail.com", "hotmial.com": "hotmail.com", "homail.com": "hotmail.com",
                "outloo.com": "outlook.com", "outlok.com": "outlook.com",
                "yaho.com": "yahoo.com", "yahooo.com": "yahoo.com",
            };
            if (domain && typos[domain]) {
                // Aviso sugestivo — NÃO bloqueia, só mostra a sugestão
                showError("email", "Voce quis dizer " + email.split("@")[0] + "@" + typos[domain] + "? Se sim, corrija. Se nao, pode continuar.");
                // NÃO seta valid = false — permite seguir
            }
        }

        // CPF
        const cpfDigits = cpf.replace(/\D/g, "");
        if (!cpfDigits || cpfDigits.length < 11) {
            showError("cpf", `CPF deve conter 11 digitos (${cpfDigits.length} informados)`);
            valid = false;
            if (!firstError) firstError = "cpf";
        } else if (cpfDigits.length > 11) {
            showError("cpf", "CPF tem digitos a mais. Confira o numero.");
            valid = false;
            if (!firstError) firstError = "cpf";
        } else if (!validarCPF(cpfDigits)) {
            showError("cpf", "CPF invalido. Verifique os digitos.");
            valid = false;
            if (!firstError) firstError = "cpf";
        }

        // Nome
        if (!name || name.split(" ").length < 2) {
            showError("name", "Informe nome e sobrenome");
            valid = false;
            if (!firstError) firstError = "name";
        }

        // Telefone
        const phoneDigits = phone.replace(/\D/g, "");
        if (!phoneDigits || phoneDigits.length < 10) {
            showError("phone", `Telefone deve ter 10 ou 11 digitos com DDD (${phoneDigits.length} informados)`);
            valid = false;
            if (!firstError) firstError = "phone";
        } else if (phoneDigits.length > 11) {
            showError("phone", "Telefone tem digitos a mais. Formato: (XX) XXXXX-XXXX");
            valid = false;
            if (!firstError) firstError = "phone";
        }

        // Scroll até o primeiro erro para ficar visível
        if (firstError) {
            const errorField = document.getElementById(`field-${firstError}`);
            errorField?.scrollIntoView({ behavior: "smooth", block: "center" });
            errorField?.focus();
        }

        if (valid) {
            // Save user data for Advanced Matching (Meta pixel uses these on next events)
            try {
                const nameParts = name.trim().split(" ");
                const userData = {
                    em: email.trim().toLowerCase(),
                    ph: "55" + phoneDigits,
                    fn: nameParts[0].toLowerCase(),
                    ln: nameParts.slice(1).join(" ").toLowerCase(),
                };
                localStorage.setItem("tess_user_data", JSON.stringify(userData));
                // Update Advanced Matching for current session events
                const vid = (window as any)._tessVid || localStorage.getItem("tess_vid") || "";
                if (typeof (window as any).fbq === "function") {
                    (window as any).fbq("init", (window as any)._fbPixelId || "", { ...userData, external_id: vid });
                }
            } catch (_) {}
        }

        return valid;
    }

    function validateStep2(): boolean {
        hideAllErrors();
        let valid = true;

        const cep = (document.getElementById("field-cep") as HTMLInputElement)?.value;

        // If autocomplete filled fields but address-fields is still hidden, show it
        const addrFields = document.getElementById("address-fields");
        if (addrFields?.classList.contains("hidden") && cep && cep.replace(/\D/g, "").length === 8) {
            addrFields.classList.remove("hidden");
        }

        const rua = (document.getElementById("field-rua") as HTMLInputElement)?.value;
        const numero = (document.getElementById("field-numero") as HTMLInputElement)?.value;
        const bairro = (document.getElementById("field-bairro") as HTMLInputElement)?.value;
        const cidade = (document.getElementById("field-cidade") as HTMLInputElement)?.value;
        const estado = (document.getElementById("field-estado") as HTMLSelectElement)?.value;

        if (!cep || cep.replace(/\D/g, "").length !== 8) {
            showError("cep", "Informe um CEP valido (8 digitos)");
            valid = false;
        }
        if (!rua || !rua.trim()) {
            showError("rua", "Informe a rua");
            valid = false;
        }
        if (!numero || !numero.trim()) {
            showError("numero", "Informe o numero");
            valid = false;
        }
        if (!bairro || !bairro.trim()) {
            showError("bairro", "Informe o bairro");
            valid = false;
        }
        if (!cidade || !cidade.trim()) {
            showError("cidade", "Informe a cidade");
            valid = false;
        }
        if (!estado) {
            showError("estado", "Selecione o estado");
            valid = false;
        }

        return valid;
    }

    // ── Finalizar Compra (PayPal Plus) ──
    document.getElementById("btn-ppplus-pay")?.addEventListener("click", () => {
        if (!ppplusRef) return;
        const btn = document.getElementById("btn-ppplus-pay") as HTMLButtonElement;
        btn.disabled = true;
        btn.innerHTML = '<span class="loading loading-spinner loading-sm"></span> Processando...';
        try {
            ppplusRef.doContinue();
        } catch (err) {
            btn.disabled = false;
            btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Finalizar Compra';
        }
    });

    // Prevent default form submit
    document.getElementById("checkout-form")?.addEventListener("submit", (e) => {
        e.preventDefault();
    });

    } // fim initCheckout

    // Inicia com retry robusto
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initCheckout, { once: true });
    } else {
        setTimeout(initCheckout, 0);
    }
</script>
