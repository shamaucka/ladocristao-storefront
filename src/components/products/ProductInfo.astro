---
import { Icon } from "astro-icon/components";

interface Variant {
    id: string;
    title: string;
    sku?: string;
    size?: string;
    price?: number;
}

interface Product {
    name: string;
    price: number;
    description: string;
    category: string;
    stock: number;
    badge?: string;
    discount?: number;
    image?: string;
    images?: string[];
    specs?: { label: string; value: string }[];
    variants?: Variant[];
}

interface Props {
    product: Product;
}

const { product } = Astro.props;

const discountedPrice = product.price * (1 - (product.discount || 0) / 100);

// Ordem canonica de tamanhos
const SIZE_ORDER = ["P", "M", "G", "GG", "XG", "XGG"];
const hasVariants = Array.isArray(product.variants) && product.variants.length > 0;
const sortedVariants = hasVariants
    ? [...product.variants!].sort((a, b) => {
        const ai = SIZE_ORDER.indexOf((a.size || a.title || "").toUpperCase());
        const bi = SIZE_ORDER.indexOf((b.size || b.title || "").toUpperCase());
        return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
    })
    : [];

// Parser de descrição em tópicos: divide por \n, •, *, ou -.
function parseDescriptionLines(desc: string): string[] {
    if (!desc) return [];
    // Divide por quebras de linha ou por bullets •, *, -
    const raw = desc
        .split(/\n|(?:^|\n)\s*[•\-\*]\s*/m)
        .map(s => s.replace(/^[•\-\*]\s*/, "").trim())
        .filter(s => s.length > 0);
    return raw;
}

const descLines = parseDescriptionLines(product.description);
---

<div
    class="product-info space-y-10"
    data-product={JSON.stringify({
        id: product.name.toLowerCase().replace(/\s+/g, "-"), // fallback
        name: product.name,
        price: product.price,
        image: product.image || (product as any).images?.[0] || "",
        category: product.category,
        discount: product.discount,
        stock: product.stock,
    })}
>
    <!-- Header Info -->
    <div class="space-y-4">
        {product.category && !product.category.includes("-") && (
            <span
                class="text-slate-500 font-black uppercase text-xs tracking-[0.3em]"
            >
                {product.category}
                {product.badge ? `/ ${product.badge}` : ""}
            </span>
        )}
        <h1
            class="text-4xl md:text-5xl font-black text-slate-950 uppercase tracking-tighter leading-tight"
        >
            {product.name}
        </h1>
        <div class="flex items-center gap-4">
            <div class="flex flex-col">
                {
                    product.discount && product.discount > 0 && (
                        <span class="text-sm font-bold text-slate-400 line-through decoration-red-500/50">
                            R$ {product.price.toLocaleString("pt-BR")}
                        </span>
                    )
                }
                <span class="text-4xl font-black text-slate-900">
                    R$ {
                        discountedPrice.toLocaleString("pt-BR", {
                            minimumFractionDigits: 0,
                            maximumFractionDigits: 0,
                        })
                    }
                </span>
                <span class="text-[11px] font-bold text-slate-400 block mt-1">
                    6x de R$ {(discountedPrice / 6).toLocaleString("pt-BR", { minimumFractionDigits: 2, maximumFractionDigits: 2 })} s/ juros
                </span>
            </div>
            <div class="flex flex-col gap-2">
                {
                    product.discount && product.discount > 0 && (
                        <span class="inline-flex items-center bg-red-50 text-red-600 font-black px-3 py-1 text-[10px] uppercase tracking-widest">
                            Economize {product.discount}%!
                        </span>
                    )
                }
                {
                    product.stock > 0 ? (
                        <span class="inline-flex items-center bg-emerald-50 text-emerald-600 font-bold px-3 py-1.5 text-xs">
                            Em Estoque
                        </span>
                    ) : (
                        <span class="inline-flex items-center bg-red-50 text-red-600 font-bold px-3 py-1.5 text-xs">
                            Esgotado
                        </span>
                    )
                }
            </div>
        </div>
    </div>

    <!-- Description -->
    <div class="space-y-4">
        <h3 class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400">
            Descricao
        </h3>
        {descLines.length > 1 ? (
            <ul class="space-y-2.5">
                {descLines.map((line) => (
                    <li class="flex items-start gap-3 text-sm leading-relaxed">
                        <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style="background:#d63384"></span>
                        <span class="text-slate-600">{line}</span>
                    </li>
                ))}
            </ul>
        ) : (
            <p class="text-slate-600 font-medium leading-relaxed">
                {product.description || "Nenhuma descricao disponivel para este produto no momento."}
            </p>
        )}
    </div>

    <!-- Specs Grid -->
    {
        product.specs && (
            <div class="grid grid-cols-2 gap-6 p-6 md:p-8 bg-slate-50 rounded-none border border-slate-100">
                {product.specs.map((spec) => (
                    <div class="space-y-1">
                        <p class="text-[10px] font-medium uppercase tracking-widest text-slate-400">
                            {spec.label}
                        </p>
                        <p class="text-sm font-semibold text-slate-900">
                            {spec.value}
                        </p>
                    </div>
                ))}
            </div>
        )
    }

    <!-- Size Selector (apenas para produtos com variantes) -->
    {hasVariants && (
        <div class="space-y-3">
            <div class="flex items-center justify-between">
                <h3 class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400">
                    Tamanho
                </h3>
                <span id="selected-size-label" class="text-xs font-bold text-[#d63384] uppercase tracking-wider"></span>
            </div>
            <div id="size-selector" class="flex flex-wrap gap-3" role="radiogroup" aria-label="Selecionar tamanho">
                {sortedVariants.map((v, idx) => (
                    <button
                        type="button"
                        class="size-btn min-w-[56px] h-12 px-4 border-2 text-sm font-black uppercase tracking-wider transition-all cursor-pointer"
                        data-variant-id={v.id}
                        data-variant-size={v.size || v.title}
                        data-variant-sku={v.sku}
                        data-selected={idx === 0 ? "true" : "false"}
                        aria-pressed={idx === 0 ? "true" : "false"}
                    >
                        {v.size || v.title}
                    </button>
                ))}
            </div>
        </div>
    )}

    <!-- Purchase Actions -->
    <div class="space-y-6 pt-4">
        <div class="grid grid-cols-1 sm:grid-cols-[auto_1fr] gap-4">
            <!-- Quantity Selector -->
            <div
                class="flex items-center border-2 border-slate-100 rounded-none p-1 shadow-sm w-fit sm:w-auto"
                style="background:#d63384"
            >
                <button
                    id="decrement-qty"
                    class="flex items-center justify-center p-4 cursor-pointer rounded-none transition-colors text-white disabled:opacity-30 hover:brightness-90"
                >
                    <Icon name="lucide:minus" class="w-[18px] h-[18px]" />
                </button>

                <span
                    id="quantity-display"
                    class="w-12 text-center text-white font-black text-xl"
                    >1</span
                >

                <button
                    id="increment-qty"
                    class="flex items-center justify-center p-4 cursor-pointer rounded-none transition-colors text-white disabled:opacity-30 hover:brightness-90"
                >
                    <Icon name="lucide:plus" class="w-[18px] h-[18px]" />
                </button>
            </div>

            <!-- Add to Cart -->
            <button
                id="add-to-cart-btn"
                class="w-full bg-primary text-white rounded-none py-5 px-8 font-black uppercase tracking-widest text-sm flex items-center justify-center gap-4 hover:bg-primary/80 transition-all active:scale-[0.98] cursor-pointer disabled:cursor-not-allowed disabled:opacity-50"
                disabled={product.stock <= 0}
            >
                <Icon name="lucide:shopping-bag" class="w-5 h-5" />
                Adicionar ao Carrinho
            </button>
        </div>
    </div>

    <!-- Benefits Banner (3 colunas estilo iCanvas) -->
    {product.category === "Camisetas" ? (
        <div class="mt-5 border border-pink-100 bg-[#fdf2f8]">
            <div class="grid grid-cols-3 divide-x divide-pink-200">
                <div class="flex flex-col items-center text-center px-3 py-5 gap-1">
                    <Icon name="lucide:tag" class="w-5 h-5 mb-1 flex-shrink-0" style="color:#d63384" />
                    <p class="text-[11px] font-black uppercase tracking-wider text-slate-800 leading-tight">Promocao Especial</p>
                    <p class="text-[10px] text-slate-600 leading-snug">Compre 3 camisetas por R$&nbsp;97</p>
                </div>
                <div class="flex flex-col items-center text-center px-3 py-5 gap-1">
                    <Icon name="lucide:truck" class="w-5 h-5 mb-1 flex-shrink-0" style="color:#d63384" />
                    <p class="text-[11px] font-black uppercase tracking-wider text-slate-800 leading-tight">Frete Fixo</p>
                    <p class="text-[10px] text-slate-600 leading-snug">R$&nbsp;19,90 para todo o Brasil</p>
                </div>
                <div class="flex flex-col items-center text-center px-3 py-5 gap-1">
                    <Icon name="lucide:rotate-ccw" class="w-5 h-5 mb-1 flex-shrink-0" style="color:#d63384" />
                    <p class="text-[11px] font-black uppercase tracking-wider text-slate-800 leading-tight">Troca Garantida</p>
                    <p class="text-[10px] text-slate-600 leading-snug">7 dias para troca ou devolucao</p>
                </div>
            </div>
        </div>
    ) : (
        <div class="mt-5 border border-slate-100 bg-[#f7f6f1]">
            <div class="grid grid-cols-3 divide-x divide-slate-200">
                <div class="flex flex-col items-center text-center px-3 py-5 gap-1">
                    <Icon name="lucide:tag" class="w-5 h-5 text-slate-500 mb-1 flex-shrink-0" />
                    <p class="text-[11px] font-black uppercase tracking-wider text-slate-800 leading-tight">Promoção Especial</p>
                    <p class="text-[10px] text-slate-500 leading-snug">Compre 3 camisetas por R$&nbsp;97</p>
                </div>
                <div class="flex flex-col items-center text-center px-3 py-5 gap-1">
                    <Icon name="lucide:truck" class="w-5 h-5 text-slate-500 mb-1 flex-shrink-0" />
                    <p class="text-[11px] font-black uppercase tracking-wider text-slate-800 leading-tight">Frete Fixo</p>
                    <p class="text-[10px] text-slate-500 leading-snug">R$&nbsp;19,90 para todo o Brasil</p>
                </div>
                <div class="flex flex-col items-center text-center px-3 py-5 gap-1">
                    <Icon name="lucide:rotate-ccw" class="w-5 h-5 text-slate-500 mb-1 flex-shrink-0" />
                    <p class="text-[11px] font-black uppercase tracking-wider text-slate-800 leading-tight">Troca Garantida</p>
                    <p class="text-[10px] text-slate-500 leading-snug">7 dias para troca ou devolução sem burocracia</p>
                </div>
            </div>
        </div>
    )}
</div>

<script>
    import { addToCart, openCart } from "../../store/cartStore";
    import { toast } from "sonner";
    // AddToCart tracking é centralizado no CartDrawer.astro

    function setupPurchaseActions() {
        const productInfo = document.querySelector(".product-info");
        if (!productInfo) return;

        const product = JSON.parse(
            productInfo.getAttribute("data-product") || "{}",
        );
        const decrementBtn = document.getElementById("decrement-qty");
        const incrementBtn = document.getElementById("increment-qty");
        const quantityDisplay = document.getElementById("quantity-display");
        const addToCartBtn = document.getElementById("add-to-cart-btn");
        const buyNowBtn = document.getElementById("buy-now-btn");

        let quantity = 1;

        const updateUI = () => {
            if (quantityDisplay) quantityDisplay.textContent = String(quantity);
            if (decrementBtn)
                (decrementBtn as HTMLButtonElement).disabled = quantity <= 1;
            if (incrementBtn)
                (incrementBtn as HTMLButtonElement).disabled =
                    quantity >= product.stock;
        };

        decrementBtn?.addEventListener("click", () => {
            if (quantity > 1) {
                quantity--;
                updateUI();
            }
        });

        incrementBtn?.addEventListener("click", () => {
            if (quantity < product.stock) {
                quantity++;
                updateUI();
            }
        });

        // Size selector
        const sizeBtns = document.querySelectorAll<HTMLButtonElement>(".size-btn");
        const sizeLabel = document.getElementById("selected-size-label");
        let selectedVariant: { id: string; size: string; sku: string } | null = null;

        function applyBtnStyles(btn: HTMLButtonElement, selected: boolean) {
            if (selected) {
                btn.style.background = "#d63384";
                btn.style.color = "#ffffff";
                btn.style.borderColor = "#d63384";
            } else {
                btn.style.background = "#ffffff";
                btn.style.color = "#0f172a";
                btn.style.borderColor = "#e2e8f0";
            }
        }

        if (sizeBtns.length > 0) {
            sizeBtns.forEach((btn) => {
                const isSel = btn.dataset.selected === "true";
                applyBtnStyles(btn, isSel);
                if (isSel) {
                    selectedVariant = {
                        id: btn.dataset.variantId || "",
                        size: btn.dataset.variantSize || "",
                        sku: btn.dataset.variantSku || "",
                    };
                    if (sizeLabel) sizeLabel.textContent = `Selecionado: ${selectedVariant.size}`;
                }

                btn.addEventListener("click", () => {
                    sizeBtns.forEach((b) => {
                        b.dataset.selected = "false";
                        b.setAttribute("aria-pressed", "false");
                        applyBtnStyles(b, false);
                    });
                    btn.dataset.selected = "true";
                    btn.setAttribute("aria-pressed", "true");
                    applyBtnStyles(btn, true);
                    selectedVariant = {
                        id: btn.dataset.variantId || "",
                        size: btn.dataset.variantSize || "",
                        sku: btn.dataset.variantSku || "",
                    };
                    if (sizeLabel) sizeLabel.textContent = `Selecionado: ${selectedVariant.size}`;
                });
            });
        }

        addToCartBtn?.addEventListener("click", () => {
            // Enriquece produto com variante selecionada (SKU + tamanho)
            const productToAdd = selectedVariant
                ? { ...product, variantId: selectedVariant.id, variantSize: selectedVariant.size, sku: selectedVariant.sku, name: `${product.name} - Tamanho ${selectedVariant.size}` }
                : product;
            const result = addToCart(productToAdd, quantity);
            if (result.success) {
                // Sem toast (redundante com abertura do sidebar)
                openCart();
            } else {
                toast.error(result.message);
            }
        });

        buyNowBtn?.addEventListener("click", () => {
            const productToAdd = selectedVariant
                ? { ...product, variantId: selectedVariant.id, variantSize: selectedVariant.size, sku: selectedVariant.sku, name: `${product.name} - Tamanho ${selectedVariant.size}` }
                : product;
            const result = addToCart(productToAdd, quantity);
            if (result.success) {
                window.location.href = "/checkout";
            } else {
                toast.error(result.message);
            }
        });

        updateUI();
    }

    // Garante que o DOM está pronto — múltiplas tentativas para robustez
    function init() {
        if (document.querySelector(".product-info")) {
            setupPurchaseActions();
        } else {
            // DOM ainda não montou — tenta de novo em breve
            setTimeout(init, 100);
        }
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init, { once: true });
    } else {
        // Defer para o próximo tick — garante que o HTML foi renderizado
        setTimeout(init, 0);
    }
</script>
