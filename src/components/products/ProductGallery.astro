---
interface Props {
    images: string[];
}

const { images: rawImages } = Astro.props;

function toHQ(url: string): string {
    if (!url) return url;
    // Galeria: 800px, f_jpg (f_auto retorna JPEG XL via CDN worker, nao suportado em Chrome)
    return url.replace(/w_\d+/g, "w_800").replace(/f_auto/g, "f_jpg").replace(/q_100/g, "q_auto");
}

const images = rawImages.map(toHQ);
const mainImage =
    images[0] ||
    "https://images.unsplash.com/photo-1550985616-10810253b84d?q=80&w=2000&auto=format&fit=crop";
---

<div class="product-gallery">
    <!-- Slider principal com swipe -->
    <div
        class="relative aspect-4/5 bg-slate-100 rounded-3xl overflow-hidden border border-slate-200 shadow-inner"
        id="gallery-slider"
    >
        <!-- Track de imagens -->
        <div
            id="gallery-track"
            class="flex h-full transition-transform duration-300 ease-out"
            style={`width: ${images.length * 100}%`}
        >
            {images.map((img, i) => (
                <div class="h-full flex-shrink-0" style={`width: ${100 / images.length}%`}>
                    <img
                        src={img}
                        alt={`Foto ${i + 1}`}
                        class="w-full h-full object-cover"
                        loading={i === 0 ? "eager" : "lazy"}
                        decoding={i === 0 ? "async" : "async"}
                        width="600"
                        height="750"
                    />
                </div>
            ))}
        </div>

        <!-- Setas (desktop) -->
        {images.length > 1 && (
            <>
                <button
                    id="gallery-prev"
                    class="absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/80 backdrop-blur-sm rounded-full flex items-center justify-center text-slate-700 hover:bg-white transition-all opacity-0 group-hover:opacity-100 shadow-sm z-10"
                    aria-label="Foto anterior"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                </button>
                <button
                    id="gallery-next"
                    class="absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/80 backdrop-blur-sm rounded-full flex items-center justify-center text-slate-700 hover:bg-white transition-all opacity-0 group-hover:opacity-100 shadow-sm z-10"
                    aria-label="Próxima foto"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </button>
            </>
        )}

        <!-- Dots indicadores (mobile) -->
        {images.length > 1 && (
            <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5 z-10">
                {images.map((_, i) => (
                    <button
                        class={`gallery-dot w-2 h-2 rounded-full transition-all ${i === 0 ? "bg-slate-900 w-5" : "bg-slate-400/50"}`}
                        data-index={i}
                        aria-label={`Foto ${i + 1}`}
                    />
                ))}
            </div>
        )}

        <!-- Contador -->
        {images.length > 1 && (
            <div class="absolute top-3 right-3 bg-black/40 backdrop-blur-sm text-white text-[10px] font-bold px-2 py-1 rounded-full z-10">
                <span id="gallery-counter">1</span>/{images.length}
            </div>
        )}
    </div>

    <!-- Thumbnails (desktop) -->
    {images.length > 1 && (
        <div class="hidden md:grid grid-cols-4 gap-3 mt-4">
            {images.map((img, index) => (
                <button
                    class={`cursor-pointer thumbnail-btn aspect-square rounded-2xl overflow-hidden border-2 transition-all p-1 ${index === 0 ? "border-slate-900 bg-white ring-4 ring-slate-900/10" : "border-slate-100 bg-slate-50"}`}
                    data-index={index}
                >
                    <img
                        src={img}
                        class="w-full h-full object-cover rounded-xl"
                        alt={`Thumbnail ${index + 1}`}
                        loading="lazy"
                        decoding="async"
                        width="150"
                        height="150"
                    />
                </button>
            ))}
        </div>
    )}
</div>

<script>
    function initGallery() {
        const slider = document.getElementById("gallery-slider");
        const track = document.getElementById("gallery-track");
        if (!slider || !track) return;

        const totalSlides = track.children.length;
        if (totalSlides <= 1) return;

        let current = 0;
        let startX = 0;
        let currentTranslate = 0;
        let prevTranslate = 0;
        let isDragging = false;
        let animationId = 0;

        const dots = document.querySelectorAll<HTMLButtonElement>(".gallery-dot");
        const thumbs = document.querySelectorAll<HTMLButtonElement>(".thumbnail-btn");
        const counter = document.getElementById("gallery-counter");
        const prevBtn = document.getElementById("gallery-prev");
        const nextBtn = document.getElementById("gallery-next");

        function goTo(index: number) {
            current = Math.max(0, Math.min(index, totalSlides - 1));
            const offset = -(current * (100 / totalSlides));
            track.style.transition = "transform 0.3s ease-out";
            track.style.transform = `translateX(${offset}%)`;
            prevTranslate = offset;
            updateIndicators();
        }

        function updateIndicators() {
            // Dots
            dots.forEach((dot, i) => {
                dot.classList.toggle("bg-slate-900", i === current);
                dot.classList.toggle("w-5", i === current);
                dot.classList.toggle("bg-slate-400/50", i !== current);
                dot.classList.toggle("w-2", i !== current);
            });
            // Thumbs
            thumbs.forEach((thumb, i) => {
                if (i === current) {
                    thumb.classList.add("border-slate-900", "bg-white", "ring-4", "ring-slate-900/10");
                    thumb.classList.remove("border-slate-100", "bg-slate-50");
                } else {
                    thumb.classList.remove("border-slate-900", "bg-white", "ring-4", "ring-slate-900/10");
                    thumb.classList.add("border-slate-100", "bg-slate-50");
                }
            });
            // Counter
            if (counter) counter.textContent = String(current + 1);
        }

        // Touch / Mouse events
        function getPositionX(event: TouchEvent | MouseEvent): number {
            return "touches" in event ? event.touches[0].clientX : event.clientX;
        }

        function dragStart(event: TouchEvent | MouseEvent) {
            isDragging = true;
            startX = getPositionX(event);
            track.style.transition = "none";
            slider.classList.add("cursor-grabbing");
        }

        function dragMove(event: TouchEvent | MouseEvent) {
            if (!isDragging) return;
            const x = getPositionX(event);
            const diff = x - startX;
            const sliderWidth = slider.offsetWidth;
            const percentDiff = (diff / sliderWidth) * (100 / totalSlides);
            currentTranslate = prevTranslate + percentDiff;
            track.style.transform = `translateX(${currentTranslate}%)`;
        }

        function dragEnd(event: TouchEvent | MouseEvent) {
            if (!isDragging) return;
            isDragging = false;
            slider.classList.remove("cursor-grabbing");

            const endX = "changedTouches" in event ? event.changedTouches[0].clientX : (event as MouseEvent).clientX;
            const diff = endX - startX;
            const threshold = slider.offsetWidth * 0.15; // 15% do slider

            if (diff < -threshold && current < totalSlides - 1) {
                goTo(current + 1);
            } else if (diff > threshold && current > 0) {
                goTo(current - 1);
            } else {
                goTo(current); // snap back
            }
        }

        // Touch
        slider.addEventListener("touchstart", dragStart, { passive: true });
        slider.addEventListener("touchmove", dragMove, { passive: true });
        slider.addEventListener("touchend", dragEnd);

        // Mouse drag
        slider.addEventListener("mousedown", dragStart);
        slider.addEventListener("mousemove", dragMove);
        slider.addEventListener("mouseup", dragEnd);
        slider.addEventListener("mouseleave", () => { if (isDragging) dragEnd(new MouseEvent("mouseup")); });

        // Prevent image drag
        track.querySelectorAll("img").forEach(img => {
            img.addEventListener("dragstart", e => e.preventDefault());
        });

        // Arrow buttons
        prevBtn?.addEventListener("click", () => goTo(current - 1));
        nextBtn?.addEventListener("click", () => goTo(current + 1));

        // Show arrows on hover (desktop)
        slider.addEventListener("mouseenter", () => {
            prevBtn?.classList.remove("opacity-0");
            nextBtn?.classList.remove("opacity-0");
        });
        slider.addEventListener("mouseleave", () => {
            if (!isDragging) {
                prevBtn?.classList.add("opacity-0");
                nextBtn?.classList.add("opacity-0");
            }
        });

        // Dots click
        dots.forEach((dot) => {
            dot.addEventListener("click", () => goTo(parseInt(dot.dataset.index || "0")));
        });

        // Thumbnails click
        thumbs.forEach((thumb) => {
            thumb.addEventListener("click", () => goTo(parseInt(thumb.dataset.index || "0")));
        });

        // Keyboard
        slider.setAttribute("tabindex", "0");
        slider.addEventListener("keydown", (e) => {
            if (e.key === "ArrowLeft") goTo(current - 1);
            if (e.key === "ArrowRight") goTo(current + 1);
        });
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initGallery, { once: true });
    } else {
        setTimeout(initGallery, 0);
    }
</script>
