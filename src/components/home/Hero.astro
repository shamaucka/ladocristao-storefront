---
import { Icon } from "astro-icon/components";
---
<section class="relative w-full h-[400px] sm:h-[500px] md:h-[580px] overflow-hidden">
    <img
        src="https://images.unsplash.com/photo-1618354691373-d851c5c3a990?q=80&w=1400&auto=format&fit=crop"
        alt="Camisetas Femininas Cristas Lado Cristao"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        decoding="sync"
        width="1400"
        height="580"
    />
    <div class="absolute inset-0 flex items-center px-8 sm:px-12 md:px-16 lg:px-24" style="background: linear-gradient(to right, rgba(214,51,132,0.85), rgba(214,51,132,0.5), rgba(214,51,132,0.15))">
        <div class="max-w-lg">
            <p class="text-[10px] font-bold uppercase tracking-[0.5em] text-white/70 mb-5">Moda Crista Premium</p>
            <h1 class="text-4xl sm:text-5xl md:text-6xl font-black text-white uppercase tracking-tighter leading-none mb-6">
                Camisetas<br/>abencoadas<br/>por Ele
            </h1>
            <p class="text-sm md:text-base text-white/85 mb-8 leading-relaxed max-w-sm">
                Camisetas femininas com mensagens cristas. Toque algodao, anti-pilling, estampa que nao desbota.
            </p>
            <a href="/camisetas" class="inline-flex items-center gap-3 bg-white px-8 py-4 text-[11px] font-black uppercase tracking-widest hover:bg-slate-100 transition-colors duration-200" style="color:#d63384">
                Ver Colecao
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
        </div>
    </div>
</section>
