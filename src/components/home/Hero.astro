---
import { Icon } from "astro-icon/components";
---
<section class="relative w-full h-[400px] sm:h-[500px] md:h-[580px] overflow-hidden">
    <img
        src="https://images.unsplash.com/photo-1513519245088-0e12902e35ca?q=80&w=1400&auto=format&fit=crop"
        alt="Quadros Decorativos Lado Cristao"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        decoding="sync"
        width="1400"
        height="580"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-transparent flex items-center px-8 sm:px-12 md:px-16 lg:px-24">
        <div class="max-w-lg">
            <p class="text-[10px] font-bold uppercase tracking-[0.5em] text-white/60 mb-5">Arte & Decor Premium</p>
            <h1 class="text-4xl sm:text-5xl md:text-6xl font-black text-white uppercase tracking-tighter leading-none mb-6">
                Transforme<br/>seus ambientes<br/>com arte
            </h1>
            <p class="text-sm md:text-base text-white/75 mb-8 leading-relaxed max-w-sm">
                Quadros decorativos em canvas poliester premium, feitos para dar vida aos seus espacos.
            </p>
            <a href="/quadros" class="inline-flex items-center gap-3 bg-white text-slate-900 px-8 py-4 text-[11px] font-black uppercase tracking-widest hover:bg-slate-100 transition-colors duration-200">
                Ver Colecao
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
        </div>
    </div>
</section>
