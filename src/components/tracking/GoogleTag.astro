---
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || "";
const AW_ID = import.meta.env.PUBLIC_GOOGLE_ADS_ID || "";
const hasGoogle = GA_ID || AW_ID;
const gtagId = AW_ID || GA_ID;
---
{hasGoogle && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gtagId}`}></script>
    <script is:inline define:vars={{ GA_ID, AW_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    // Consent Mode v2 defaults (non-EU but best practice)
    gtag('consent', 'default', {
      'ad_storage': 'granted',
      'ad_user_data': 'granted',
      'ad_personalization': 'granted',
      'analytics_storage': 'granted'
    });

    if (GA_ID) gtag('config', GA_ID, { 'send_page_view': true });
    if (AW_ID) gtag('config', AW_ID, { 'send_page_view': false });
    </script>
  </>
)}
