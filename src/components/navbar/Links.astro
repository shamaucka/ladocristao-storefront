---
const links = [
    { name: "Inicio", href: "/" },
    { name: "Camisetas", href: "/camisetas" },
    { name: "Almofadas", href: "/almofadas" },
    { name: "Mais Vendidos", href: "/camisetas?sort=mais-vendidos" },
    { name: "Lançamentos", href: "/camisetas?sort=novidades" },
    { name: "Minha Conta", href: "/minhaconta" },
];
---
<div class="hidden lg:block bg-white border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center h-10 gap-8">
        {links.map((link) => (
            <a href={link.href} class="text-[11px] font-medium uppercase tracking-widest text-slate-500 hover:text-[#d63384] transition-colors duration-200 whitespace-nowrap">{link.name}</a>
        ))}
    </div>
</div>
