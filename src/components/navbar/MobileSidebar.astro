---
import { Icon } from "astro-icon/components";

const links = [
    { name: "Inicio", href: "/" },
    { name: "Camisetas", href: "/camisetas" },
    { name: "Quadros", href: "/quadros" },
    { name: "Almofadas", href: "/almofadas" },
    { name: "Esculturas", href: "/esculturas" },
    { name: "Minha Conta", href: "/minhaconta" },
];
---
<div id="mobile-sidebar" class="fixed inset-0 z-[1000] lg:hidden pointer-events-none">
    <div id="sidebar-overlay" class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-300"></div>
    <div id="sidebar-panel" class="absolute top-0 left-0 h-full w-72 bg-white shadow-2xl -translate-x-full transition-transform duration-300 ease-in-out flex flex-col">
        <div class="flex items-center justify-between px-5 h-16 border-b border-slate-100">
            <a href="/"><img src="/logo.png" alt="Lado Cristao" class="h-8 w-auto" width="80" height="32" /></a>
            <button id="sidebar-close-btn" class="w-8 h-8 flex items-center justify-center text-slate-500 hover:text-slate-900 transition-colors" aria-label="Fechar menu">
                <Icon name="lucide:x" class="w-4 h-4" />
            </button>
        </div>
        <nav class="flex-1 overflow-y-auto py-4">
            {links.map((link) => (
                <a href={link.href} class="flex items-center px-5 py-3.5 text-sm font-medium text-slate-700 hover:bg-slate-50 hover:text-slate-900 transition-colors border-b border-slate-50">
                    {link.name}
                </a>
            ))}
        </nav>
    </div>
</div>
