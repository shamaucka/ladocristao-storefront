---
import { Icon } from "astro-icon/components";
---
<footer class="bg-slate-200 text-slate-700 pt-16 pb-8 mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
            <!-- Brand -->
            <div class="col-span-1 lg:col-span-1">
                <a href="/" class="inline-block mb-6">
                    <img src="/logo.png" alt="Lado Cristao" class="h-24 w-auto" width="288" height="144" />
                </a>
                <p class="text-slate-600 mb-8 leading-relaxed text-sm">
                    Moda crista feminina para expressar sua fe no dia a dia. Qualidade, estilo e proposito em cada peca.
                </p>
                <div class="flex gap-3">
                    <a href="#" class="w-9 h-9 flex items-center justify-center border border-slate-400 text-slate-600 hover:text-white hover:border-transparent transition-colors" style="--hover-bg:#d63384" onmouseover="this.style.background='#d63384'; this.style.borderColor='#d63384'" onmouseout="this.style.background=''; this.style.borderColor=''" aria-label="Instagram">
                        <Icon name="lucide:instagram" class="w-4 h-4" />
                    </a>
                </div>
            </div>
            <!-- Loja -->
            <div>
                <h3 class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-6">Loja</h3>
                <ul class="space-y-3">
                    {[
                        { label: "Camisetas", href: "/camisetas" },
                        { label: "Almofadas", href: "/almofadas" },
                        { label: "Mais Vendidas", href: "/camisetas?sort=mais-vendidos" },
                        { label: "Lançamentos", href: "/camisetas?sort=novidades" },
                        { label: "Minha Conta", href: "/minhaconta" },
                    ].map(l => (
                        <li><a href={l.href} class="text-sm text-slate-600 hover:text-[#d63384] transition-colors duration-200">{l.label}</a></li>
                    ))}
                </ul>
            </div>
            <!-- Políticas -->
            <div>
                <h3 class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-6">Políticas</h3>
                <ul class="space-y-3">
                    {[
                        { label: "Política de Entrega", href: "/politica-de-entrega" },
                        { label: "Trocas e Devoluções", href: "/politica-de-trocas-e-devolucoes" },
                        { label: "Política de Reembolso", href: "/politica-de-reembolso" },
                        { label: "Política de Privacidade", href: "/politica-de-privacidade" },
                        { label: "Termos de Uso e LGPD", href: "/termos-de-uso" },
                    ].map(l => (
                        <li><a href={l.href} class="text-sm text-slate-600 hover:text-[#d63384] transition-colors duration-200">{l.label}</a></li>
                    ))}
                </ul>
            </div>
            <!-- Atendimento -->
            <div>
                <h3 class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-6">Atendimento</h3>
                <p class="text-sm text-slate-600 mb-4 leading-relaxed">Dúvidas, trocas, devoluções ou qualquer assunto:</p>
                <a href="mailto:contato@ladocristao.com.br" class="text-sm font-bold hover:underline underline-offset-2" style="color:#d63384">
                    contato@ladocristao.com.br
                </a>
                <p class="text-xs text-slate-500 mt-2">Seg a Sex, 08h às 17h</p>

                <h3 class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mt-8 mb-4">Newsletter</h3>
                <div class="flex">
                    <input type="email" placeholder="seu@email.com" class="flex-1 px-4 py-3 text-sm bg-white border border-slate-300 text-slate-800 placeholder-slate-400 outline-none focus:border-[#d63384] transition-colors" />
                    <button class="px-4 py-3 text-white text-sm font-black transition-colors hover:brightness-90" style="background:#d63384" aria-label="Inscrever">
                        <Icon name="lucide:arrow-right" class="w-4 h-4" />
                    </button>
                </div>
            </div>
        </div>
        <div class="border-t border-slate-300 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-slate-500">
            <p>&copy; {new Date().getFullYear()} Lado Cristao. Todos os direitos reservados.</p>
            <div class="flex gap-6">
                <a href="/politica-de-privacidade" class="hover:text-[#d63384] transition-colors">Privacidade</a>
                <a href="/termos-de-uso" class="hover:text-[#d63384] transition-colors">Termos de Uso</a>
            </div>
        </div>
    </div>
</footer>
