---
import Layout from "../layouts/Layout.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import CardProduct from "../components/products/CardProduct.astro";
import { fetchProducts } from "../lib/api";
import { products as staticProducts } from "../data/products";
import { Icon } from "astro-icon/components";

const apiProducts = await fetchProducts(500);
const products = apiProducts || staticProducts;

const ITEMS_PER_PAGE = 48;
const totalPages = Math.ceil(products.length / ITEMS_PER_PAGE);
const breadcrumbItems = [{ label: "Inicio", href: "/" }, { label: "Quadros" }];
---

<Layout title="Quadros Decorativos | Lado Cristao">
    <!-- Banner Promocional -->
    <div class="bg-black text-white">
        <div class="max-w-7xl mx-auto px-6 py-8 md:py-12 text-center">
            <p class="text-xs md:text-sm uppercase tracking-[0.3em] text-white/60 mb-3">Oferta Especial</p>
            <h2 class="text-3xl md:text-5xl font-black uppercase tracking-tight">
                Compre 2 Quadros por <span class="text-white">R$ 150</span>
            </h2>
            <p class="text-lg md:text-xl mt-2 font-light tracking-wide">
                + Frete Gratis
            </p>
            <p class="text-xs md:text-sm text-white/40 mt-4 uppercase tracking-widest">
                Valido enquanto durarem os estoques
            </p>
        </div>
    </div>

    <div class="bg-white min-h-screen pb-20 pt-6">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
                <p id="product-count" class="text-slate-400 text-sm">
                    {products.length} quadros disponiveis
                </p>

                <!-- Filtro de ordenacao -->
                <div class="flex items-center gap-3">
                    <label class="text-xs font-bold uppercase tracking-widest text-slate-400">Ordenar por</label>
                    <select
                        id="sort-select"
                        class="select select-bordered select-sm rounded-lg bg-white border-slate-200 text-sm font-medium min-w-[180px]"
                    >
                        <option value="mais-vendidos">Mais Vendidos</option>
                        <option value="novidades">Lançamentos</option>
                        <option value="promocao">Promoção</option>
                        <option value="menor-preco">Menor Preço</option>
                        <option value="maior-preco">Maior Preço</option>
                        <option value="a-z">A - Z</option>
                        <option value="z-a">Z - A</option>
                    </select>
                </div>
            </div>

            <main>
                <!-- Grid de produtos -->
                <div id="products-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6 md:gap-8">
                    {products.map((product, i) => (
                        <div
                            class="product-card"
                            data-index={i}
                            data-name={product.name}
                            data-price={product.price}
                            data-slug={product.slug}
                            style={i >= ITEMS_PER_PAGE ? "display:none" : ""}
                        >
                            <CardProduct
                                title={product.name}
                                price={product.price}
                                images={product.images}
                                stock={product.stock}
                                slug={product.slug}
                            />
                        </div>
                    ))}
                </div>

                <!-- Paginacao -->
                <div id="pagination" class="flex items-center justify-center gap-2 mt-12">
                    <button
                        id="prev-page"
                        class="btn btn-sm btn-outline rounded-lg border-slate-200 hover:bg-black hover:text-white hover:border-black disabled:opacity-30"
                        disabled
                    >
                        <Icon name="lucide:chevron-left" class="w-4 h-4" />
                    </button>

                    <div id="page-numbers" class="flex items-center gap-1">
                        <!-- JS generates page buttons -->
                    </div>

                    <button
                        id="next-page"
                        class="btn btn-sm btn-outline rounded-lg border-slate-200 hover:bg-black hover:text-white hover:border-black"
                    >
                        <Icon name="lucide:chevron-right" class="w-4 h-4" />
                    </button>
                </div>
            </main>
        </div>
    </div>
</Layout>

<script define:vars={{ ITEMS_PER_PAGE, totalPages }}>
    // Lê sort da URL (?sort=novidades, ?sort=mais-vendidos, ?sort=promocao)
    const urlSort = new URLSearchParams(window.location.search).get("sort");
    const validSorts = ["mais-vendidos", "novidades", "promocao", "menor-preco", "maior-preco", "a-z", "z-a"];
    let currentSort = validSorts.includes(urlSort) ? urlSort : "mais-vendidos";
    let currentPage = 1;

    const allCards = [...document.querySelectorAll(".product-card")];
    const grid = document.getElementById("products-grid");
    const pageNumbers = document.getElementById("page-numbers");
    const prevBtn = document.getElementById("prev-page");
    const nextBtn = document.getElementById("next-page");
    const sortSelect = document.getElementById("sort-select");
    const countEl = document.getElementById("product-count");

    // Pré-seleciona o sort no dropdown
    if (sortSelect) sortSelect.value = currentSort;

    // Extrai número QUADRO do slug para ordenar por lançamento
    function extractQuadroNum(slug) {
        // Busca no data-slug o padrão de imagem ou usa index
        // Produtos mais novos têm QUADRO maior (QUADRO515 > QUADRO001)
        const card = allCards.find(c => c.dataset.slug === slug);
        if (!card) return 0;
        // Tenta pegar da URL da imagem dentro do card
        const img = card.querySelector("img");
        const src = img?.getAttribute("src") || "";
        const match = src.match(/QUADRO(\d+)/);
        return match ? parseInt(match[1]) : 0;
    }

    function getSortedIndices() {
        const indices = allCards.map((card, i) => ({
            i,
            name: card.dataset.name || "",
            price: parseFloat(card.dataset.price || "0"),
            slug: card.dataset.slug || "",
            quadroNum: extractQuadroNum(card.dataset.slug || ""),
        }));

        switch (currentSort) {
            case "menor-preco":
                indices.sort((a, b) => a.price - b.price);
                break;
            case "maior-preco":
                indices.sort((a, b) => b.price - a.price);
                break;
            case "novidades":
                // Lançamentos: maior QUADRO = mais novo
                indices.sort((a, b) => b.quadroNum - a.quadroNum);
                break;
            case "a-z":
                indices.sort((a, b) => a.name.localeCompare(b.name));
                break;
            case "z-a":
                indices.sort((a, b) => b.name.localeCompare(a.name));
                break;
            case "promocao":
            default: // mais-vendidos e promocao = original order
                break;
        }

        return indices.map((item) => item.i);
    }

    function renderPage() {
        const sorted = getSortedIndices();
        const start = (currentPage - 1) * ITEMS_PER_PAGE;
        const end = start + ITEMS_PER_PAGE;
        const visible = new Set(sorted.slice(start, end));

        // Reorder DOM
        const fragment = document.createDocumentFragment();
        for (const idx of sorted) {
            fragment.appendChild(allCards[idx]);
        }
        grid.appendChild(fragment);

        // Show/hide
        allCards.forEach((card, i) => {
            const sortedIndex = sorted.indexOf(i);
            card.style.display = sortedIndex >= start && sortedIndex < end ? "" : "none";
        });

        // Update pagination UI
        renderPagination();

        // Scroll to top of grid
        if (currentPage > 1) {
            grid.scrollIntoView({ behavior: "smooth", block: "start" });
        }
    }

    function renderPagination() {
        const total = Math.ceil(allCards.length / ITEMS_PER_PAGE);
        pageNumbers.innerHTML = "";

        prevBtn.disabled = currentPage <= 1;
        nextBtn.disabled = currentPage >= total;

        // Show max 7 page buttons
        let startPage = Math.max(1, currentPage - 3);
        let endPage = Math.min(total, startPage + 6);
        if (endPage - startPage < 6) startPage = Math.max(1, endPage - 6);

        for (let p = startPage; p <= endPage; p++) {
            const btn = document.createElement("button");
            btn.className = p === currentPage
                ? "btn btn-sm rounded-lg bg-black text-white border-black min-w-[36px]"
                : "btn btn-sm btn-outline rounded-lg border-slate-200 hover:bg-black hover:text-white hover:border-black min-w-[36px]";
            btn.textContent = String(p);
            btn.addEventListener("click", () => { currentPage = p; renderPage(); });
            pageNumbers.appendChild(btn);
        }

        // Update count text
        const start = (currentPage - 1) * ITEMS_PER_PAGE + 1;
        const end = Math.min(currentPage * ITEMS_PER_PAGE, allCards.length);
        countEl.textContent = `Mostrando ${start}-${end} de ${allCards.length} quadros`;
    }

    // Events
    prevBtn.addEventListener("click", () => { if (currentPage > 1) { currentPage--; renderPage(); } });
    nextBtn.addEventListener("click", () => { const total = Math.ceil(allCards.length / ITEMS_PER_PAGE); if (currentPage < total) { currentPage++; renderPage(); } });
    sortSelect.addEventListener("change", (e) => { currentSort = e.target.value; currentPage = 1; renderPage(); });

    // Init
    renderPage();
</script>
