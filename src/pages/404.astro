---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404" description="Erro 404 - Pagina nao encontrada" noindex={true}>
  <section
    class="min-h-[calc(100vh-100px)] flex flex-col items-center justify-center px-6 text-center"
  >
    <h1 class="text-7xl md:text-8xl font-extrabold text-primary mb-6">404</h1>

    <h2 class="text-2xl md:text-3xl text-base-content font-semibold mb-6">
      Pagina nao encontrada :/
    </h2>

    <p class="text-base-content/80 max-w-md mx-auto mb-10 font-bold">
      O link que voce tentou acessar nao existe ou foi movido. Mas nao se preocupe,
      voce pode voltar para a pagina inicial e continuar navegando.
    </p>

    <a
      href="/"
      class="rounded-full bg-primary px-8 py-3 text-lg font-bold text-primary-content transition-all duration-150 active:translate-y-0.5 active:drop-shadow-none"
    >
      Voltar para o inicio
    </a>
  </section>
</Layout>
